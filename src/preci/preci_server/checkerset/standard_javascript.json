{
  "checkerSetId": "standard_javascript",
  "checkerSetName": "腾讯代码规范 (Javascript) 规则集",
  "toolName": "ESLINT",
  "checkers": [
    "prefer-const",
    "no-const-assign",
    "no-var",
    "no-new-object",
    "quote-props",
    "no-array-constructor",
    "prefer-template",
    "template-curly-spacing",
    "no-eval",
    "no-useless-escape",
    "wrap-iife",
    "no-loop-func",
    "no-dupe-class-members",
    "no-duplicate-imports",
    "no-multi-assign",
    "operator-linebreak",
    "no-case-declarations",
    "no-mixed-operators",
    "nonblock-statement-body-position",
    "brace-style",
    "spaced-comment",
    "eol-last",
    "space-infix-ops",
    "padded-blocks",
    "no-multiple-empty-lines",
    "space-in-parens",
    "array-bracket-spacing",
    "max-len",
    "block-spacing",
    "func-call-spacing",
    "comma-style",
    "camelcase",
    "new-cap",
    "semi"
  ]
}